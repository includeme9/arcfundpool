{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@arcfundpool/config": ["packages/config/index.ts"],
      "@arcfundpool/config/*": ["packages/config/*"],
      "@arcfundpool/types": ["packages/types/index.ts"],
      "@arcfundpool/types/*": ["packages/types/*"],
      "@arcfundpool/utils": ["packages/utils/index.ts"],
      "@arcfundpool/utils/*": ["packages/utils/*"],
      "@arcfundpool/validation": ["packages/validation/index.ts"],
      "@arcfundpool/validation/*": ["packages/validation/*"],
      "@arcfundpool/web3": ["packages/web3/index.ts"],
      "@arcfundpool/web3/*": ["packages/web3/*"],
      "@arcfundpool/database": ["packages/database/index.ts"],
      "@arcfundpool/database/*": ["packages/database/*"],
      "@arcfundpool/ui": ["packages/ui/index.ts"],
      "@arcfundpool/ui/*": ["packages/ui/*"]
    }
  }
}
